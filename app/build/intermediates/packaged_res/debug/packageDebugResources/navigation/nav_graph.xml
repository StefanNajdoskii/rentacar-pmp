<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/carListFragment">

    <fragment
        android:id="@+id/carListFragment"
        android:name="com.rentacar.cars.CarListFragment"
        android:label="@string/title_cars"
        tools:layout="@layout/fragment_car_list">
        <action
            android:id="@+id/action_carList_to_carDetail"
            app:destination="@id/carDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/carDetailFragment"
        android:name="com.rentacar.cars.CarDetailFragment"
        android:label="@string/title_car_detail"
        tools:layout="@layout/fragment_car_detail">
        <argument
            android:name="carId"
            app:argType="string" />
        <action
            android:id="@+id/action_carDetail_to_booking"
            app:destination="@id/bookingFragment" />
    </fragment>

    <fragment
        android:id="@+id/bookingFragment"
        android:name="com.rentacar.booking.BookingFragment"
        android:label="@string/title_booking"
        tools:layout="@layout/fragment_booking">
        <argument
            android:name="carId"
            app:argType="string" />
        <action
            android:id="@+id/action_booking_to_payment"
            app:destination="@id/paymentFragment" />
    </fragment>

    <fragment
        android:id="@+id/paymentFragment"
        android:name="com.rentacar.payment.PaymentFragment"
        android:label="@string/title_payment"
        tools:layout="@layout/fragment_payment">
        <argument
            android:name="bookingId"
            app:argType="string" />
        <argument
            android:name="totalPrice"
            app:argType="float" />
        <argument
            android:name="carName"
            app:argType="string" />
        <argument
            android:name="startDate"
            app:argType="long"
            android:defaultValue="0L" />
        <argument
            android:name="endDate"
            app:argType="long"
            android:defaultValue="0L" />
        <argument
            android:name="pickupLocation"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/bookingHistoryFragment"
        android:name="com.rentacar.booking.BookingHistoryFragment"
        android:label="@string/title_bookings"
        tools:layout="@layout/fragment_booking_history">
        <action
            android:id="@+id/action_bookingHistory_to_payment"
            app:destination="@id/paymentFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.rentacar.profile.ProfileFragment"
        android:label="@string/title_profile"
        tools:layout="@layout/fragment_profile" />

</navigation>
